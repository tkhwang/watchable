{
  "name": "@life-logs/monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "clean:dist": "rm -rf apps/*/dist packages/*/dist",
    "clean:all": "pnpm run clean:dist && pnpm run clean && rm -rf .turbo apps/*/.turbo packages/*/.turbo"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "sharp"]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  }
}
